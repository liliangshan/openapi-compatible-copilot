{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2020",
		"outDir": "out",
		"lib": ["ES2020", "DOM"],
		"types": ["node"],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "Node16",
		"declaration": true
	},
	"exclude": ["node_modules", ".vscode-test", "out"]
}
