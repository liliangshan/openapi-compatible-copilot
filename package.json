{
	"name": "openapi-compatible-copilot",
	"publisher": "liliangshan",
	"displayName": "LLS OAI",
	"description": "OpenAI-compatible OR Anthropic for Copilot Chat",
	"icon": "assets/logo.png",
	"version": "2.1.0",
	"engines": {
		"vscode": "^1.104.0"
	},
	"extensionDependencies": [
		
	],
	"categories": [
		"AI",
		"Chat"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/liliangshan/openapi-compatible-copilot"
	},
	"enabledApiProposals": [
		"chatProvider"
	],
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "openapicopilot",
				"displayName": "LLS OAI"
			}
		],
		"commands": [
			{
				"command": "openapicopilot.manageProviders",
				"category": "LLS OAI",
				"title": "Manage Providers"
			},
			{
				"command": "openapicopilot.openConfig",
				"category": "LLS OAI",
				"title": "Open Configuration UI"
			},
			{
				"command": "openapicopilot.openGlobalSettingsTab",
				"category": "LLS OAI",
				"title": "Open Global Settings"
			},
			{
				"command": "openapicopilot.openProjectSettingsTab",
				"category": "LLS OAI",
				"title": "Open Project Settings"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "openapicopilot.manageProviders"
				},
				{
					"command": "openapicopilot.openConfig"
				},
				{
					"command": "openapicopilot.openGlobalSettingsTab"
				},
				{
					"command": "openapicopilot.openProjectSettingsTab"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "openapi-copilot",
					"title": "LLS OAI",
					"icon": "$(plug)"
				}
			]
		},
		"views": {
			"openapi-copilot": [
				{
					"type": "webview",
					"id": "openapicopilot.configView",
					"name": "Provider Management",
					"icon": "$(plug)"
				}
			]
		},
		"configuration": {
			"title": "LLS OAI",
			"properties": {
				"openapicopilot.systemPrompt": {
					"type": "string",
					"default": "",
					"description": "Custom system prompt to prepend to system messages",
					"scope": "resource"
				},
				"openapicopilot.language": {
					"type": "string",
					"enum": [
						"auto",
						"en",
						"zh-cn",
						"zh-tw",
						"ko",
						"ja",
						"fr",
						"de"
					],
					"default": "auto",
					"description": "Display language for the LLS OAI UI. Auto follows the VS Code display language.",
					"scope": "application"
				}
			}
		}
	},
	"main": "./out/extension.js",
	"activationEvents": [
	
	],
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "eslint src",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/vscode": "^1.104.0",
		"@types/node": "^20.0.0",
		"typescript": "^5.6.0",
		"@vscode/vsce": "^3.0.0"
	}
}
